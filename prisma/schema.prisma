generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  websiteUrl  String?
  logoUrl     String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                String            @id @default(cuid())
  name              String
  brandId           String
  brand             Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  size              Int
  price             Float
  images            String[]
  concentration     String
  gender            String
  description       String            @db.Text
  discountAmount    Float             @default(0)
  isFeatured        Boolean           @default(false)
  isBestSeller      Boolean           @default(false)
  stock             Int               @default(0)
  fragranceProfiles String[]
  topNotes          String[]
  heartNotes        String[]
  baseNotes         String[]
  reviews           Review[]
  reservations      CartReservation[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([brandId])
  @@index([isFeatured])
  @@index([isBestSeller])
}

model CartReservation {
  id            String   @id @default(cuid())
  cartSessionId String
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity      Int
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([cartSessionId, productId])
  @@index([cartSessionId])
  @@index([productId])
  @@index([expiresAt])
}

model Review {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviewerName  String   @default("")
  reviewerEmail String
  rating        Int
  title         String   @default("")
  comment       String   @default("") @db.Text
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([reviewerEmail])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique

  customerName    String
  customerEmail   String
  customerPhone   String?

  shippingAddress String
  shippingCity    String
  shippingZip     String
  shippingCountry String

  items           Json
  testerItem      Json?
  subtotal        Float
  shippingCost    Float    @default(0)
  total           Float

  promoCode       String?
  promoDiscount   Float    @default(0)

  stripeSessionId String?  @unique
  stripePaymentId String?
  paymentStatus   String   @default("pending")

  orderStatus     String   @default("processing")

  shippingMethod      String   @default("gls")
  boxnowLockerId      String?
  boxnowLockerName    String?
  boxnowLockerAddress String?
  boxnowDeliveryId    String?
  boxnowParcelId      String?
  boxnowStatus        String?

  trackingNumber  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paidAt          DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  @@index([customerEmail])
  @@index([orderNumber])
  @@index([paymentStatus])
  @@index([orderStatus])
}

model PromoCode {
  id                   String    @id @default(cuid())
  code                 String    @unique
  discountType         String
  discountValue        Float
  maxDiscountAmount    Float?
  minOrderValue        Float     @default(0)
  startsAt             DateTime?
  endsAt               DateTime?
  usageLimitTotal      Int?
  usageLimitPerUser    Int?
  timesUsed            Int       @default(0)
  freeShipping         Boolean   @default(false)
  appliesToSaleItems   Boolean   @default(true)
  stackable            Boolean   @default(false)
  isActive             Boolean   @default(true)
  requiredProductNames String[]  // <-- NEW: cart must contain at least one of these
  createdAt            DateTime  @default(now())

  @@index([code])
  @@index([isActive])
}

model EmailCapture {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
